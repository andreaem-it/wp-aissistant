DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5432/rag
EMBED_DIM=768
# Schema is managed by Alembic (`alembic upgrade head`). Set true to auto-create tables
# from the models on startup instead — quick dev spin-up only, not for production.
DB_AUTO_CREATE=false
# RAG retrieval: fetch a wider pool then MMR-rerank to k relevant-but-diverse chunks.
RETRIEVE_FETCH_K=20
MMR_LAMBDA=0.5
CHAT_MODEL=ollama/llama3.1
EMBED_MODEL=ollama/nomic-embed-text
LLM_API_BASE=http://localhost:11434
# Token for the /admin/clients onboarding endpoints. Leave unset to disable the admin API.
ADMIN_API_KEY=change-me
# Rate limits (requests per 60s window). /chat is limited per client+IP, ingest per client.
CHAT_RATE_LIMIT=30
INGEST_RATE_LIMIT=60
# CORS: origins allowed for the panel app (comma-separated). Client widget origins are
# configured per-client via /admin/clients/{id}/origins.
PANEL_ORIGINS=http://localhost:5173
# true (default) reflects any Origin; set false to enforce the allowlist strictly in the browser.
CORS_ALLOW_ALL=true
# Run the background ingest worker inside the app process. Set false if you run a
# dedicated worker process instead (the queue is shared via Postgres).
INGEST_WORKER_ENABLED=true
# Structured JSON logs; DEBUG/INFO/WARNING/ERROR.
LOG_LEVEL=INFO
# Optional: POST a JSON notification here whenever a new ticket is opened (Slack incoming
# webhook, Zapier/n8n/Make, or your own endpoint). Leave unset to disable.
OPERATOR_WEBHOOK_URL=
